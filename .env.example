# Server-only credential for the approved tweet retrieval provider.
# Required in production; development falls back to fixture tweet context when empty.
TWITTERAPI_IO_API_KEY=

# Two separate Vercel AI Gateway keys, both required in production. They are
# billed independently with no fallback between them. Development uses local
# draft models when a key is empty.
#
# Manual Workspace runs. No spend limit.
AI_GATEWAY_API_KEY=
# Automated (cron / Discovery Sweep) runs. Give this key a Vercel spend limit
# (e.g. $5/day) to cap automated spend without affecting manual runs above.
AI_GATEWAY_AUTOMATED_API_KEY=

# Required in production. These launch defaults can be changed in Vercel and redeployed.
AI_GATEWAY_OPENAI_MODEL=openai/gpt-5.4-mini
AI_GATEWAY_ANTHROPIC_MODEL=anthropic/claude-sonnet-4.6
AI_GATEWAY_GOOGLE_MODEL=google/gemini-3-flash

# Optional image model used for selected news-linked image variations.
AI_GATEWAY_IMAGE_MODEL=google/gemini-2.5-flash-image

# Optional Vercel AI Gateway base URL override.
AI_GATEWAY_BASE_URL=

# Required in production. The app POSTs sourceTweet, replySignals, and usersDirection as JSON.
# In development, leaving this empty allows text-only local runs and disables news-linked images.
OUTSIDE_X_ENRICHMENT_ENDPOINT=

# Required when OUTSIDE_X_ENRICHMENT_ENDPOINT is set. Sent as a service-to-service bearer token.
OUTSIDE_X_ENRICHMENT_API_KEY=

# Required by this repository's standalone /enrich route when using it as the enrichment endpoint.
SERPER_API_KEY=

# Optional Vercel AI Gateway model for summarizing Serper findings in the /enrich route.
OUTSIDE_X_ENRICHMENT_MODEL=google/gemini-3-flash

# --- Supabase (server-side persistence + single-operator auth) ---
# All four are server-only: per ADR-0019 the browser reaches Supabase only
# through server routes, so none of these carry a NEXT_PUBLIC_ prefix and the
# service-role key never reaches the client bundle.
# When all are set, the email-OTP operator gate is enforced; when unset, the app
# runs open with fixture/local fallbacks (local development).
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# The Operator Allowlist: a comma-separated set of emails allowed to sign in, each
# provisioning its own Operator Account on first sign-in. Membership decides
# allowlisting; every other email is refused a code. Unset/empty means nobody is
# allowed. Normalized (trimmed + lower-cased) and de-duplicated.
#
# The FIRST entry is load-bearing — it is the Primary Operator the unattended Discovery
# Sweep anchors under (seen-tweet/cluster/baseline dedup + the single composition).
# Always APPEND new teammates; reordering or removing the first entry re-anchors
# discovery under empty dedup state and can start duplicate runs.
OPERATOR_ALLOWLISTED_EMAILS=

# --- Automated Discovery Sweep scheduling (issue 021) ---
# The unattended sweep runs as a Vercel Cron job that hits /api/discovery-sweep
# every 2 hours (schedule in vercel.json). These configure that route.

# Comma-separated operator-owned X List ids covering the Discovery Source
# (~5 lists for ~5000 follows). Required for the sweep to read any timeline; with
# none set the route refuses (503) rather than sweeping nothing.
DISCOVERY_SOURCE_LIST_IDS=

# Shared-secret protecting the sweep route. Vercel Cron automatically sends it as
# `Authorization: Bearer <CRON_SECRET>`. Required in production (an unprotected
# public endpoint must never start paid runs); in development the route allows an
# unauthenticated local trigger when this is empty.
CRON_SECRET=

# Optional. Trailing-window lookback in hours. Defaults to 3 — larger than the
# 2-hour cron interval so consecutive windows overlap and lose nothing at the edges
# (the seen-tweet record makes overlap safe). Raise it if you lengthen the interval.
DISCOVERY_SWEEP_LOOKBACK_HOURS=

# Required in production for automated runs. A server-driven Automated Run has no
# incoming HTTP request, so it has no request origin to build the served-image URLs
# (`/api/runs/:id/images/:optionId`) it stores. Set this to the production base URL
# (e.g. https://<your-production-domain>); it defaults to http://localhost:3000,
# which would leave automated runs' image URLs unreachable in production.
APP_BASE_URL=

# bot-triggered runs secret that hits the /api/bot-ingest route
BOT_INGEST_SECRET=